<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRadventure.DashboardPage"
             Title="Explora">

    <Grid>
        <Image Source="dashboard.png" 
               Aspect="AspectFill" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill"/>

        <BoxView BackgroundColor="#CC0A140E" />

        <CollectionView x:Name="cvTours" 
                        Margin="15"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,10" 
                            BackgroundColor="#1C2520" 
                            HeightRequest="380" 
                            WidthRequest="350"
                            Stroke="#20FFFFFF"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20">

                        <VerticalStackLayout>
                            <Grid HeightRequest="200">
                                <Image Source="{Binding ImagenUrl}" 
                                       Aspect="AspectFill" 
                                       WidthRequest="350"/>

                                <Label Text="NEW!" 
                                       BackgroundColor="#93C94A" 
                                       TextColor="Black" 
                                       Padding="8,2" 
                                       Margin="12" 
                                       FontAttributes="Bold" 
                                       FontSize="10"
                                       HorizontalOptions="Start" 
                                       VerticalOptions="Start"/>
                            </Grid>

                            <VerticalStackLayout Padding="15" Spacing="6">
                                <Label Text="{Binding NombreLugar}" 
                                       TextColor="White" 
                                       FontSize="18" 
                                       FontAttributes="Bold"/>

                                <Label Text="★★★★★" 
                                       TextColor="#FFD700" 
                                       FontSize="14"/>

                                <Label Text="{Binding IdiomasTexto}" 
                                       TextColor="#B0BEC5" 
                                       FontSize="12" 
                                       FontAttributes="Italic"/>

                                <Label Text="{Binding DescripcionCorta}" 
                                       TextColor="#B0BEC5" 
                                       FontSize="12"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>

                                <HorizontalStackLayout Spacing="10" Margin="0,5,0,0">
                                    <Label Text="{Binding PrecioVisual}" 
                                           TextColor="#93C94A" 
                                           FontSize="16" 
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding DuracionMinutos, StringFormat='{0} min'}" 
                                           TextColor="#78909C" 
                                           FontSize="14" 
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ImageButton Source="editar.png" 
                     WidthRequest="70" 
                     HeightRequest="70"
                     HorizontalOptions="End" 
                     VerticalOptions="End"
                     Margin="30"
                     BackgroundColor="Transparent"
                     Clicked="OnAgregarTourClicked" />
    </Grid>
</ContentPage>