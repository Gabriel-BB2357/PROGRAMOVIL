<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CRadventure.MainPage"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- Imagen de fondo -->
        <Image
            Source="mono.jpg"
            Aspect="AspectFill" />

        <!-- Oscurecer fondo -->
        <BoxView Color="#80000000" />

        <ScrollView>

            <VerticalStackLayout Padding="25,40,25,20"
                                 Spacing="15">

                <!-- Logo y nombre -->
                <HorizontalStackLayout Spacing="10">

                    <Frame
                        WidthRequest="60"
                        HeightRequest="60"
                        CornerRadius="15"
                        Padding="0"
                        HasShadow="False"
                        BackgroundColor="#40000000">

                        <Image Source="logo.png"/>
                    </Frame>

                    <VerticalStackLayout VerticalOptions="Center">

                        <Label
                            Text="CRAdventure"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#054205"/>


                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- Texto principal -->
                <VerticalStackLayout Margin="0,30,0,0">

                    <Label
                        Text="Costa Rica"
                        FontSize="42"
                        FontAttributes="Bold"
                        TextColor="#EBEE3F"/>

                    <Label
                        FontSize="42"
                        FontAttributes="Bold">

                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Redescubre nuestro pais "
                                      TextColor="#054205"/>

                            </FormattedString>
                        </Label.FormattedText>
                    </Label>




                </VerticalStackLayout>



                <!-- Panel Login -->
                <Frame
                    Margin="0,20,0,20"
                    CornerRadius="30"
                    Padding="25"
                    BackgroundColor="#CC000000"
                    BorderColor="#40FFFFFF">

                    <VerticalStackLayout Spacing="20">

                        <Label
                            Text="Bienvenido de nuevo"
                            HorizontalOptions="Center"
                            FontSize="32"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Label
                            Text="Inicia sesión para continuar tu aventura"
                            HorizontalOptions="Center"
                            FontSize="14"
                            TextColor="#CCCCCC"/>

                        <!-- Email -->
                        <Frame
    CornerRadius="15"
    Padding="15,8"
    BackgroundColor="#30FFFFFF"
    HasShadow="False">

                            <Entry
        x:Name="txtCorreo"
        Placeholder="Correo electrónico"
        PlaceholderColor="#BBBBBB"
        TextColor="White"/>

                        </Frame>

                        <!-- Password -->
                        <Frame
    CornerRadius="15"
    Padding="15,8"
    BackgroundColor="#30FFFFFF"
    HasShadow="False">

                            <Entry
        x:Name="txtPassword"
        Placeholder="Contraseña"
        IsPassword="True"
        PlaceholderColor="#BBBBBB"
        TextColor="White"/>

                        </Frame>

                        <!-- Botón Login -->
                        <Button
                            Text="Iniciar sesión"
                            HeightRequest="55"
                            CornerRadius="18"
                            BackgroundColor="#8BC34A"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="18"
                            Clicked="Login_Clicked"/>

                        <Grid ColumnDefinitions="*,Auto,*">

                            <BoxView
                                HeightRequest="1"
                                BackgroundColor="#555555"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="1"
                                Margin="15,0"
                                Text="o"
                                TextColor="White"/>

                            <BoxView
                                Grid.Column="2"
                                HeightRequest="1"
                                BackgroundColor="#555555"
                                VerticalOptions="Center"/>

                        </Grid>

                        <!-- Registro -->
                        <Button
                            Text="Registrarse"
                            HeightRequest="55"
                            CornerRadius="18"
                            BackgroundColor="Transparent"
                            BorderColor="#8BC34A"
                            BorderWidth="1"
                            TextColor="White"
                            Clicked="Registrar_Clicked"/>

                        <Label
                            Text="¿Olvidaste tu contraseña?"
                            HorizontalOptions="Center"
                            TextColor="#8BC34A"/>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>