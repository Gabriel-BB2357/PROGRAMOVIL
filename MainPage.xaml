<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CRadventure.MainPage"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- Imagen de fondo -->
        <Image
            Source="a3.png"
        Aspect="AspectFill"
        HorizontalOptions="FillAndExpand"
        VerticalOptions="FillAndExpand"  />

      
    

        <ScrollView>

            <VerticalStackLayout Padding="25,40,25,20"
                                 Spacing="15">

                <!-- Logo y nombre -->
                <HorizontalStackLayout Spacing="10">

                    <Frame
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="60"
                        Padding="-20"
                        HasShadow="false"
                        BackgroundColor="AliceBlue">

                        <Image Source="logo.png"/>
                    </Frame>

                    <VerticalStackLayout VerticalOptions="Center">

                        <Label
                         Text="CR"
                          FontFamily="Kaushan"
                          FontSize="40"
                          TextColor="#008000"/>
                        <Label
                          Text="Adventure"
                           FontFamily="Kaushan"
                            FontSize="40"
                            TextColor="#215B22"/>

                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- Texto principal -->
                <VerticalStackLayout Margin="0,30,0,0">

                    <Label
    Text="Costa Rica"
    FontFamily="Kaushan"
    FontSize="45"
    TextColor="#143E1E"/>

                    <Label
                        FontFamily="Kaushan"
                        FontSize="50">
                        

                        <Label.FormattedText>
                            <FormattedString>
                            <Span Text="Redescubre&#10;"
                                   FontFamily="Kaushan"
                                TextColor="#143E1E"/>



                            <Span
                Text="nuestro país"
                                 FontFamily="Kaushan"
                TextColor="#143E1E"/>

                        </FormattedString>
                        </Label.FormattedText>
                    </Label>




                </VerticalStackLayout>



                <!-- Panel Login -->
                <Frame
                    Margin="0,20,0,20"
                    CornerRadius="30"
                    Padding="25"
                    BackgroundColor="#CC000000"
                    BorderColor="#40FFFFFF">

                    <VerticalStackLayout Spacing="20">

                        <Label
    Text="Bienvenido de nuevo"
    HorizontalOptions="Center"
    FontFamily="Kaushan"
    FontSize="30"
    TextColor="White"/>

                        <Label
    Text="Inicia sesión para continuar tu aventura"
    FontSize="18"
    HorizontalOptions="Center"
                             FontFamily="Kaushan"
    TextColor="#EAEAEA"/>

                        <!-- Email -->
                        <Frame
    CornerRadius="15"
    Padding="15,8"
    BackgroundColor="#30FFFFFF"
    HasShadow="False">

                            <Entry
        x:Name="txtCorreo"
        Placeholder="Correo electrónico"
        PlaceholderColor="#BBBBBB"
        TextColor="White"/>

                        </Frame>

                        <!-- Password -->
                        <Frame
    CornerRadius="15"
    Padding="15,8"
    BackgroundColor="#30FFFFFF"
    HasShadow="False">

                            <Entry
        x:Name="txtPassword"
        Placeholder="Contraseña"
        IsPassword="True"
        PlaceholderColor="#BBBBBB"
        TextColor="White"/>

                        </Frame>

                        <!-- Botón Login -->
                        <Button
    Text="Iniciar viaje""
    FontFamily="Kaushan"
    FontSize="24"
    BackgroundColor="#93C94A"
    TextColor="White"
    HeightRequest="65"
    CornerRadius="22"/>

                        <Grid ColumnDefinitions="*,Auto,*">

                            <BoxView
                                HeightRequest="1"
                                BackgroundColor="#555555"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="1"
                                Margin="15,0"
                                Text="o"
                                TextColor="White"/>

                            <BoxView
                                Grid.Column="2"
                                HeightRequest="1"
                                BackgroundColor="#555555"
                                VerticalOptions="Center"/>

                        </Grid>

                        <!-- Registro -->
                        <Button
                            Text="Registrarse"
                            HeightRequest="55"
                            CornerRadius="18"
                            BackgroundColor="Transparent"
                            BorderColor="#8BC34A"
                            BorderWidth="1"
                            TextColor="White"
                            Clicked="Registrar_Clicked"/>

                        <Label
                            Text="¿Olvidaste tu contraseña?"
                            HorizontalOptions="Center"
                            TextColor="#8BC34A"/>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>