<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRadventure.RegisterPage"
             Title="RegisterPage">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="Crear cuenta" FontSize="24" HorizontalOptions="Center" />

            <Entry x:Name="txtNombre" Placeholder="Nombre" />
            <Entry x:Name="txtApellidos" Placeholder="Apellidos" />
            <Entry x:Name="txtCorreo" Placeholder="Correo electrónico" Keyboard="Email" />
            <Entry x:Name="txtTelefono" Placeholder="Teléfono" Keyboard="Telephone" />
            <Entry x:Name="txtPassword" Placeholder="Contraseña" IsPassword="True" />
            <Entry x:Name="txtConfirmPassword" Placeholder="Confirmar contraseña" IsPassword="True" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="¿Es extranjero?" VerticalOptions="Center" />
                <Switch x:Name="switchExtranjero" />
            </HorizontalStackLayout>

            <Button Text="Registrarme" Clicked="Registrar_Clicked" />
            <Button Text="Volver" Clicked="Volver_Clicked" BackgroundColor="Transparent" TextColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>